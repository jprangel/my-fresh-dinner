    { "name": "Feta cheese", "quantity": "30g (optional)" }
  ],
  "steps": [
    { "step": 1, "instruction": "Preheat oven to 200°C and halve bell peppers." },
    { "step": 2, "instruction": "Heat olive oil, sauté onion and garlic until soft." },
    { "step": 3, "instruction": "Add turkey mince and cook until browned." },
    { "step": 4, "instruction": "Stir in lentils, tomato paste, paprika, and oregano." },
    { "step": 5, "instruction": "Fill peppers with mixture and bake for 20 minutes." },
    { "step": 6, "instruction": "Top with feta cheese before serving." }
