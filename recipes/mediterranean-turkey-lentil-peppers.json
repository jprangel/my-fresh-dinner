    { "name": "Onion", "quantity": "1 small" },
    { "name": "Garlic clove", "quantity": "1" },
    { "name": "Tomato paste", "quantity": "1 tbsp" },
    { "name": "Paprika", "quantity": "1 tsp" },
    { "name": "Oregano", "quantity": "1 tsp" },
