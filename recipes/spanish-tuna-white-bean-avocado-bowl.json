  "steps": [
    { "step": 1, "instruction": "Drain and rinse the cannellini beans and tuna." },
    { "step": 2, "instruction": "Halve the cherry tomatoes, thinly slice the red onion, and cube the avocado." },
    { "step": 3, "instruction": "Arrange spinach as the base in two bowls." },
    { "step": 4, "instruction": "Top with tuna, cannellini beans, cherry tomatoes, red onion, avocado, and capers." },
    { "step": 5, "instruction": "Whisk together lemon juice and olive oil, then drizzle over both bowls." },
    { "step": 6, "instruction": "Season with black pepper and serve immediately." }
